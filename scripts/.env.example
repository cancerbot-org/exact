# Copy this file to .env at the project root and fill in the values.
# All scripts load .env automatically — no need to pass vars inline.

# ── Required ──────────────────────────────────────────────────────────

# Remote trials database (provided by CancerBot team)
TRIALS_DATABASE_URL=postgresql://user:password@host:5432/dbname

# Patient database (CTOMOP)
PATIENT_DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── trials4patients.sh options ────────────────────────────────────────

# Comma-separated person IDs to process (default: all patients)
#PERSON_IDS=20291,20292,20293

# Max number of patients to process (default: all)
#PATIENT_LIMIT=50

# Top N trials returned per patient (default: 20)
#SEARCH_LIMIT=5

# If set, also writes evaluator-compatible CSV to this path
#RESULTS_CSV=results.csv
