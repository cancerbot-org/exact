SECRET_KEY=change-me
DEBUG=true
DATABASE_NAME=exact
DATABASE_USER=exact
DATABASE_PASSWORD=
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Required for compare / trials4patients scripts:
TRIALS_DATABASE_URL=postgresql://user:password@host:5432/dbname
PATIENT_DATABASE_URL=postgresql://user:password@host:5432/dbname

REDIS_URL=redis://localhost:6379
ENVIRONMENT=local

# PostGIS (if not in system PATH)
# macOS (Homebrew): GDAL_LIBRARY_PATH=/opt/homebrew/lib/libgdal.dylib
# macOS (Homebrew): GEOS_LIBRARY_PATH=/opt/homebrew/lib/libgeos_c.dylib
# Linux:            GDAL_LIBRARY_PATH=/usr/lib/libgdal.so
# Linux:            GEOS_LIBRARY_PATH=/usr/lib/libgeos_c.so
